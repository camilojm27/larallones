meta {
  name: Forgot Password
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/forgot-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "email": "{{testEmail}}"
  }
}

tests {
  test("returns 200", () => {
    expect(res.status).to.equal(200);
  });

  test("returns status message", () => {
    expect(res.body.status).to.be.a("string");
  });
}
